{
	// User-owned wrangler config for this Flue app. Flue reads this file,
	// merges its own contributions into an ignored Vite input config
	// (`.flue-vite.wrangler.jsonc`), and the official Cloudflare Vite
	// integration emits the deployable Worker output.
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "cloudflare",
	"compatibility_date": "2026-06-01",
	"compatibility_flags": ["nodejs_compat"],
	// Migration history is user-authored: adding an agent = new exported
	// function + mount + a migration tag for its generated class
	// (`Flue<PascalName>Agent`, derived from the agent function's name).
	// Renaming an agent FUNCTION is a storage-identity change — express it
	// with wrangler-native `renamed_classes`.
	"migrations": [
		{
			"tag": "flue-class-FlueWithCloudflareBindingAgent",
			"new_sqlite_classes": ["FlueWithCloudflareBindingAgent"]
		},
		{
			"tag": "flue-class-FlueSkillsFromGitAgent",
			"new_sqlite_classes": ["FlueSkillsFromGitAgent"]
		},
		{
			"tag": "flue-class-FlueSkillsFromR2Agent",
			"new_sqlite_classes": ["FlueSkillsFromR2Agent"]
		}
	],
	"ai": {
		"binding": "AI"
	},
	// Worker Loader binding (beta) required by the cf-shell `code` tool.
	// See examples in this directory: skills-from-r2.ts, skills-from-git.ts.
	// If your account doesn't have Worker Loader access, comment this out
	// — the agents that use it (skills-from-r2, skills-from-git) will
	// throw at sandbox-construction with a clear error, but the rest of
	// the example (with-cloudflare-binding) keeps working.
	"worker_loaders": [{ "binding": "LOADER" }],
	// R2 bucket used by skills-from-r2.ts as the hydration source.
	// `preview_bucket_name` lets wrangler dev (in --remote mode) use a
	// separate bucket so you don't have to seed prod. Seed the dev bucket
	// with examples/cloudflare/seed-r2.sh before running.
	"r2_buckets": [
		{
			"binding": "KNOWLEDGE_BASE",
			"bucket_name": "flue-example-knowledge-base",
			"preview_bucket_name": "flue-example-knowledge-base-dev"
		}
	]
}
